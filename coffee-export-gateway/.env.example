PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Fabric Network
CHANNEL_NAME=coffeechannel
CHAINCODE_NAME=ecta
FABRIC_NETWORK_AS_LOCALHOST=true

# CA Admin (for registering new exporters)
CA_ADMIN_USER=admin
CA_ADMIN_PASSWORD=adminpw

# Organization
ORG_NAME=ECTAOrg
ORG_MSP_ID=ECTAOrgMSP
